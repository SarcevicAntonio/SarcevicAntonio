		"globals": "^17.4.0",
		"license-report": "^6.8.2",
		"mdsvex": "^0.12.7",
		"playwright": "^1.59.1",
		"postcss": "^8.5.9",
		"postcss-load-config": "^6.0.1",
		"postcss-mixins": "^12.1.2",
		"postcss-preset-env": "^11.2.0",
		"prettier": "^3.8.1",
